{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "Mongo": {
    "ConnectionString": "Example: mongodb://<user>:<password>@<host>:<port>/?authSource=admin",
    "Database": "Example: my_database_name"
  },

  "Jwt": {
    "Key": "Example: your-very-secure-secret-key",
    "Issuer": "Example: your-app-name",
    "Audience": "Example: your-app-users",
    "ExpireMinutes": "Example: 15"
  },

  "RefreshToken": {
    "ExpireDays": "Example: 7"
  },

  "Argon2": {
    "Iterations": "Example: 3",
    "MemorySize": "Example: 131072",
    "DegreeOfParallelism": "Example: 2",
    "SaltSize": "Example: 16",
    "HashSize": "Example: 32"
  }
}
